{
  "manifest_version": 3,
  "name": "Arc-Style Tab Switcher",
  "version": "2.0.0",
  "description": "MRU tab switching with a visual overlay, just like Arc browser",
  "permissions": ["tabs", "activeTab", "scripting", "favicon"],
  "commands": {
    "switch-tab": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Open MRU tab switcher overlay"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
